      "cell_type": "code",
      "source": [
        "# ==========================================\n",
        "# CELL 10: MISSINGNESS ANALYTICS & VISUALIZATION\n",
        "# Why: Quantify missing data to plan defensive data-cleaning strategies.\n",
        "# ==========================================\n",
        "\n",
        "null_counts = df.isnull().sum()\n",
        "null_percentages = (df.isnull().sum() / len(df)) * 100\n",
        "\n",
        "# Consolidate diagnostics matrix\n",
        "null_df = pd.DataFrame({\n",
        "    'Absolute Nulls': null_counts,\n",
        "    'Percentage (%)': null_percentages\n",
        "}).sort_values(by='Percentage (%)', ascending=False)\n",
        "\n",
        "print(\"=== CRITICAL MISSING DATA COMPOSITION ===\")\n",
        "print(null_df[null_df['Absolute Nulls'] > 0])\n",
        "\n",
        "# Render executive diagnostic visualization\n",
        "plt.figure(figsize=(10, 5))\n",
        "sns.barplot(x=null_df['Percentage (%)'], y=null_df.index, hue=null_df.index, legend=False, palette=\"Reds_r\")\n",
        "plt.title(\"Relative Missing Value Ratios per Structural Attribute\", fontsize=14, weight='bold')\n",
        "plt.xlabel(\"Percentage of Total Observations (%)\")\n",
        "plt.ylabel(\"Dataset Columns\")\n",
        "plt.axvline(x=5.0, color='red', linestyle='--', label='Critical Drop Threshold (5%)')\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
